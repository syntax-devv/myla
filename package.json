{
  "name": "myla",
  "version": "0.1.0",
  "description": "Terminal AI orchestrator with React Ink",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "myla": "bin/myla.js"
  },
  "scripts": {
    "dev": "tsx src/ui/App.tsx",
    "dev:watch": "tsx watch src/ui/App.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "tsx --test src/**/*.test.{ts,tsx}"
  },
  "keywords": [
    "ai",
    "terminal",
    "cli",
    "orchestrator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^12.0.0",
    "node-pty": "^1.0.0",
    "openai": "^4.52.0",
    "react": "^18.3.1",
    "sql.js": "^1.12.0",
    "strip-ansi": "^7.1.0",
    "toml": "^4.1.1",
    "wrap-ansi": "^9.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
